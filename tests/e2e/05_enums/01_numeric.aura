// Expected output:
// 1
// 2
// 10
// 11
// 12
// 1
// 0
// true
// false

enum Direction {
  Up = 1,
  Down,
}

enum Status {
  Ok = 10,
  Err,
  Pending,
}

let u: Direction = Direction.Up;
let d: Direction = Direction.Down;

print u;

// 1
print d;

// 2

let ok: Status = Status.Ok;
let err: Status = Status.Err;
let p: Status = Status.Pending;

print ok;

// 10
print err;

// 11
print p;

// 12

// Test equality
if (u == Direction.Up) {
  print 1;
} else {
  print 0;
}

if (u == Direction.Down) {
  print 1;
} else {
  print 0;
}

print u == Direction.Up;
print u == Direction.Down;
