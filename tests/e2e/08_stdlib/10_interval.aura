let count = 0;
let id = 0;

function onInterval(): void {
  count = count + 1;
  print "COUNT_IS";
  print count;
  print "ID_IN_CLOSURE";
  print id;
  if (count == 3) {
    print "STOP_NOW";
    clearInterval(id);
  }
}

id = setInterval(onInterval, 50);
print "ID_IS";
print id;

print "Interval started";
