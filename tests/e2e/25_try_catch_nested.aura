// Expected output:
// Outer try
// Inner try
// In fail
// Inner finally
// Caught in outer:
// Fail

function fail(): void {
  print "In fail";
  throw new Error("Fail");
}

function outer(): void {
  try {
    print "Outer try";
    try {
      print "Inner try";
      fail();
    } finally {
      print "Inner finally";
    }
  } catch (e: Error) {
    print "Caught in outer:";
    print e;
  }
}

outer();
