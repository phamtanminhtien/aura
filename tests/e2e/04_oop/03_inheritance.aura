// Expected output:
// Woof!

class Animal {
  public speak(): string {
    return "Generic animal sound";
  }
}

class Dog extends Animal {
  public override speak(): string {
    return "Woof!";
  }
}

function makeItSpeak(a: Animal): void {
  print a.speak();
}

let d = new Dog();
makeItSpeak(d);

// Outputs: Woof!
