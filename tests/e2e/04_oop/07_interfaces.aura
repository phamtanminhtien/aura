// Expected output:
// Log: Hello world
// Quack!

interface Logger {
    log(message: string): void;
}

class MyLogger implements Logger {
    log(message: string): void {
        print("Log: " + message);
    }
}

function doLog(l: Logger, msg: string) {
    l.log(msg);
}

let logger: Logger = new MyLogger();
doLog(logger, "Hello world");

// Structural typing check
interface Quacker {
    quack(): void;
}

class Duck {
    quack(): void {
        print("Quack!");
    }
}

let q: Quacker = new Duck();
q.quack();
