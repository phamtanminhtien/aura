// Expected output:
// UP
// DOWN
// UP
// DOWN
// 1
// 0
// true
// false

enum DirectionStr {
    Up = "UP",
    Down = "DOWN"
}

print(DirectionStr.Up);
print(DirectionStr.Down);

let u: DirectionStr = DirectionStr.Up;
let d: DirectionStr = DirectionStr.Down;

print(u);
print(d);

// Test equality
if (u == DirectionStr.Up) {
    print(1);
} else {
    print(0);
}

if (u == DirectionStr.Down) {
    print(1);
} else {
    print(0);
}

print(u == DirectionStr.Up);
print(u == DirectionStr.Down);