// Test: Array Literals and Indexing
// Expected output:
// 10
// 2
// 3
// apple
// banana
// 3
// 2
// 1
// 3
// 5
// nested assignment works
// [10, 2, 3]
// [[5, 2], [3, 4]]
// [["A", "B"], ["C", "D"]]
// [[[1]]]

let numbers = [1, 2, 3];
numbers[0] = 10;
print numbers[0];
print numbers[1];
print numbers[2];

let fruits: string[] = ["apple", "banana"];
print fruits[0];
print fruits[1];

print numbers.len();
print fruits.len();

let nested = [[1, 2], [3, 4]];
print nested[0][0];
print nested[1][0];
nested[0][0] = 5;
print nested[0][0];
if (nested[0][0] == 5) {
  print "nested assignment works";
}
print numbers;
print nested;

let strings = [["A", "B"], ["C", "D"]];
print strings;

let deep = [[[1]]];
print deep;
