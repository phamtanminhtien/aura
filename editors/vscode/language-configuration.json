{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "/**", "close": " */", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{[^}]*$|^.*\\([^)]*$|^.*\\[[^]]*$",
    "decreaseIndentPattern": "^\\s*[\\}\\]\\)]"
  },
  "onEnterRules": [
    {
      "beforeText": { "pattern": "^\\s*/\\*\\*(?!/)(?:(?!\\*/).)*$" },
      "afterText": { "pattern": "^\\s*\\*/$" },
      "action": { "indent": "indentOutdent", "appendText": " * " }
    },
    {
      "beforeText": { "pattern": "^\\s*/\\*\\*(?!/)(?:(?!\\*/).)*$" },
      "action": { "indent": "none", "appendText": " * " }
    },
    {
      "beforeText": { "pattern": "^(\\s*)\\*(?!/)(?:(?!\\*/).)*$" },
      "action": { "indent": "none", "appendText": "* " }
    },
    {
      "beforeText": { "pattern": "^\\s*\\*/\\s*$" },
      "action": { "indent": "none", "removeText": 1 }
    }
  ]
}
