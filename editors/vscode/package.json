{
  "name": "aura-vscode",
  "displayName": "Aura Support",
  "description": "Language support for the Aura programming language",
  "version": "0.1.0",
  "publisher": "aura-lang",
  "icon": "icon/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "aura",
        "aliases": [
          "Aura",
          "aura"
        ],
        "extensions": [
          ".aura"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon/aura-file-icon.png",
          "dark": "./icon/aura-file-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "aura",
        "scopeName": "source.aura",
        "path": "./syntaxes/aura.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Aura",
      "properties": {
        "aura.serverPath": {
          "type": "string",
          "default": "aura",
          "description": "Path to the Aura language server binary. If not specified, the extension will attempt to find it in the PATH or target/debug/aura."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "typescript": "^4.9.5",
    "eslint": "^8.34.0",
    "@typescript-eslint/parser": "^5.53.0",
    "@typescript-eslint/eslint-plugin": "^5.53.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
