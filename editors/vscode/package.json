{
  "name": "aura-vscode",
  "displayName": "Aura Support",
  "description": "Language support for the Aura programming language",
  "version": "0.1.0",
  "publisher": "aura-lang",
  "icon": "icon/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:aura",
    "onCommand:aura.restartServer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "aura",
        "aliases": [
          "Aura",
          "aura"
        ],
        "extensions": [
          ".aura"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon/aura-file-icon.png",
          "dark": "./icon/aura-file-icon.png"
        }
      }
    ],
    "commands": [
      {
        "command": "aura.restartServer",
        "title": "Restart Language Server",
        "category": "Aura"
      }
    ],
    "grammars": [
      {
        "language": "aura",
        "scopeName": "source.aura",
        "path": "./syntaxes/aura.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Aura",
      "properties": {
        "aura.serverPath": {
          "type": "string",
          "default": "aura",
          "description": "Path to the Aura language server binary. Defaults to 'aura' (system PATH) if not specified."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "bundle-dev": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch-bundle": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "npm run bundle && npx vsce package"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.53.0",
    "@typescript-eslint/parser": "^5.53.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.34.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
