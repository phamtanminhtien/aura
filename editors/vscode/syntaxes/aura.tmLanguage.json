{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aura",
  "scopeName": "source.aura",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#template-literals"
    },
    {
      "include": "#decorators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#classes"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.aura",
          "begin": "/\\*\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.aura",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.documentation.aura",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.aura",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.aura",
          "match": "\\b(if|else|while|for|return|try|catch|throw|finally|match|new|import|from|export|as|async|await|is)\\b"
        },
        {
          "name": "keyword.declaration.aura",
          "match": "\\b(class|constructor|interface|type|enum|abstract|override)\\b"
        },
        {
          "name": "storage.modifier.aura",
          "match": "\\b(static|readonly|public|protected|private)\\b"
        },
        {
          "name": "storage.type.aura",
          "match": "\\b(let|const|var)\\b"
        },
        {
          "name": "keyword.other.aura",
          "match": "\\b(this|print|super)\\b"
        },
        {
          "name": "constant.language.aura",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aura",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.aura",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.aura",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.aura",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "template-literals": {
      "name": "string.quoted.template.aura",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "constant.character.escape.aura",
          "match": "\\\\."
        },
        {
          "name": "variable.interpolation.aura",
          "begin": "\\${",
          "end": "}",
          "patterns": [
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "decorators": {
      "name": "meta.decorator.aura",
      "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
      "captures": {
        "0": {
          "name": "entity.name.function.decorator.aura"
        }
      }
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.aura",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.aura",
          "match": "\\b(i32|i64|u32|u64|f32|f64|bool|string|char|void|number|any|unknown|Promise|TCPStream|TCPServer|HTTPClient|HTTPRequest|HTTPResponse|Date|Error|Result|Map|Set|Array)\\b"
        },
        {
          "name": "entity.name.type.aura",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.aura",
          "match": "\\b(\\+|-|\\*|/|%|\\*\\*)\\b"
        },
        {
          "name": "keyword.operator.logical.aura",
          "match": "\\b(&&|\\|\\||!)\\b"
        },
        {
          "name": "keyword.operator.comparison.aura",
          "match": "\\b(==|!=|<|>|<=|>=)\\b"
        },
        {
          "name": "keyword.operator.assignment.aura",
          "match": "(\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.other.aura",
          "match": "(\\?\\?|\\|>|=>|\\?|\\.)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "storage.type.function.aura"
            },
            "2": {
              "name": "entity.name.function.aura"
            }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.aura"
            }
          }
        }
      ]
    },
    "classes": {
      "match": "\\b(class|interface|enum|type)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": {
          "name": "keyword.declaration.aura"
        },
        "2": {
          "name": "entity.name.type.class.aura"
        }
      }
    },
    "constants": {
      "patterns": [
        {
          "name": "variable.other.constant.aura",
          "match": "\\b[A-Z][A-Z0-9_]*\\b"
        }
      ]
    }
  }
}
